# ============================================================
# SellerIQ .gitignore
# ============================================================

# ------------------------------------------------------------
# Credentials and config
# ------------------------------------------------------------
config.py

# ------------------------------------------------------------
# Local raw report files
# ------------------------------------------------------------
# Raw reports are stored in S3. The local folder is a temporary
# buffer and should never be committed.
raw_reports/

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.eggs/

# ------------------------------------------------------------
# Virtual environment
# ------------------------------------------------------------
.venv/
venv/
env/

# ------------------------------------------------------------
# Environment files
# ------------------------------------------------------------
.env
.env.*

# ------------------------------------------------------------
# OS files
# ------------------------------------------------------------
.DS_Store
Thumbs.db

# ------------------------------------------------------------
# IDE / editor
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
